# Training & Placement Portal - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================
TNP_DB_HOST=localhost
TNP_DB_USER=root
TNP_DB_PASS=
TNP_DB_NAME=placement

# ============================================
# Email Configuration (SMTP)
# ============================================
# Gmail SMTP Settings
# For Gmail, you need to use an App Password, not your regular password
# Generate App Password: https://support.google.com/accounts/answer/185833
TNP_SMTP_EMAIL=your-email@gmail.com
TNP_SMTP_PASS=your-app-password

# SMTP Server Settings (Gmail)
TNP_SMTP_HOST=smtp.gmail.com
TNP_SMTP_PORT=587
TNP_SMTP_SECURE=tls

# Email Sender Information
TNP_EMAIL_FROM_NAME=T&P SVNIT
TNP_EMAIL_FROM_EMAIL=your-email@gmail.com

# ============================================
# Application Configuration
# ============================================
# Base URL for the application (for production)
# Leave empty for auto-detection
TNP_BASE_URL=

# Application Name
TNP_APP_NAME=Training & Placement Portal

# ============================================
# Security Configuration
# ============================================
# Session timeout in seconds (default: 1800 = 30 minutes)
TNP_SESSION_TIMEOUT=1800

# CSRF token expiration in seconds (default: 3600 = 1 hour)
TNP_CSRF_EXPIRY=3600

# ============================================
# File Upload Configuration
# ============================================
# Maximum file upload size in bytes (default: 524288 = 512KB)
TNP_MAX_UPLOAD_SIZE=524288

# Allowed image MIME types (comma-separated)
TNP_ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/jpg

# ============================================
# Development/Production Mode
# ============================================
# Set to 'production' for production environment
# Set to 'development' for development environment
TNP_ENVIRONMENT=development

# Enable error display (only for development)
# Set to 1 for development, 0 for production
TNP_DISPLAY_ERRORS=1

